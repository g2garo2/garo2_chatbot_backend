APP_NAME=Garo2 API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=garo2

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=https://garo2.com
OPENROUTER_SITE_NAME=Garo2

BACKEND_BASE_URL=http://127.0.0.1:8000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
CORS_ORIGINS=http://localhost:5173,https://garo2.com,https://www.garo2.com,https://admin.garo2.com
