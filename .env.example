APP_NAME=Garo2 API
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=garo2

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_FREE_MODEL=openai/gpt-4o-mini
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=https://garo2.com
OPENROUTER_SITE_NAME=Garo2
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_PLAN_PLUS=plan_xxx_plus
RAZORPAY_PLAN_PRO=plan_xxx_pro
RAZORPAY_PLAN_ULTRA=plan_xxx_ultra
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

BACKEND_BASE_URL=https://api.garo2.com
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
CORS_ORIGINS=https://garo2.com,https://www.garo2.com,https://admin.garo2.com
